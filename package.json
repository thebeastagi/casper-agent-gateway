{
  "name": "beast-casper-agent-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Beast AI Agent Gateway — Multi-agent coordination on Casper Network via x402 micropayments",
  "workspaces": [
    "packages/core",
    "packages/gateway",
    "packages/mcp-server",
    "packages/agent-sdk"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "pretest": "npm run build",
    "test": "node --test packages/core/test/*.test.js packages/gateway/test/*.test.js packages/mcp-server/test/*.test.js packages/agent-sdk/test/*.test.js",
    "gateway": "npm run start -w @beast/agent-gateway",
    "mcp": "npm run start -w @beast/casper-mcp-server",
    "demo:fleet": "npm run demo:fleet -w @beast/agent-sdk",
    "demo:marketplace": "npm run demo:services -w @beast/agent-sdk"
  },
  "keywords": [
    "casper",
    "x402",
    "ai-agent",
    "multi-agent",
    "defi",
    "mcp",
    "blockchain",
    "web3"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  }
}